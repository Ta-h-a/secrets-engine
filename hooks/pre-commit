#!/usr/bin/env bash
#
# SecretLens Pre-commit Hook
# Runs SecretLens on staged files before commit
#

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

log_info()    { echo -e "${BLUE}[INFO]${NC} $1" >&2; }
log_success() { echo -e "${GREEN}[OK]${NC} $1" >&2; }
log_warn()    { echo -e "${YELLOW}[WARN]${NC} $1" >&2; }
log_error()   { echo -e "${RED}[ERROR]${NC} $1" >&2; }

print_header() {
    echo "" >&2
    echo -e "${BOLD}╔══════════════════════════════════════════════════════════════════╗${NC}" >&2
    echo -e "${BOLD}║           🔒 SecretLens Security Scan                        ║${NC}" >&2
    echo -e "${BOLD}╚══════════════════════════════════════════════════════════════════╝${NC}" >&2
    echo "" >&2
}

find_secretlens_binary() {
    if [[ -n "${SECRETLENS_BIN:-}" ]] && [[ -x "$SECRETLENS_BIN" ]]; then
        echo "$SECRETLENS_BIN"
        return
    fi
    
    for candidate in \
        "$HOME/.secretlens/bin/secretlens" \
        "$HOME/Documents/work/hackathon/pre-commit-engine/target/release/secretlens" \
        "$HOME/Documents/work/hackathon/pre-commit-engine/target/debug/secretlens" \
        "$(git rev-parse --show-toplevel 2>/dev/null)/target/release/secretlens" \
        "$(git rev-parse --show-toplevel 2>/dev/null)/target/debug/secretlens" \
        "/usr/local/bin/secretlens"
    do
        if [[ -x "$candidate" ]]; then
            echo "$candidate"
            return
        fi
    done
    
    if command -v secretlens &>/dev/null; then
        echo "secretlens"
        return
    fi
    
    echo ""
}

find_desktop_app() {
    if [[ -n "${SECRETLENS_DESKTOP:-}" ]]; then
        echo "$SECRETLENS_DESKTOP"
        return
    fi
    
    # Try to find electron in the desktop directory
    local desktop_dir="$HOME/Documents/work/hackathon/pre-commit-engine/desktop"
    
    if [[ -x "$desktop_dir/node_modules/.bin/electron" ]]; then
        echo "$desktop_dir"
        return
    fi
    
    echo ""
}

main() {
    print_header
    
    SECBIN=$(find_secretlens_binary)
    
    if [[ -z "$SECBIN" ]]; then
        log_error "SecretLens binary not found"
        log_info "Install: cd pre-commit-engine && ./install.sh"
        exit 0
    fi
    
    log_success "Found: $SECBIN"
    
    # Collect staged files
    mapfile -t STAGED_FILES < <(git diff --cached --name-only --diff-filter=ACM -z | tr '\0' '\n')
    
    if [[ ${#STAGED_FILES[@]} -eq 0 ]]; then
        log_info "No files staged, skipping"
        exit 0
    fi
    
    log_info "Scanning ${#STAGED_FILES[@]} file(s)..."
    
    # Build JSON payload
    PAYLOAD=$(python3 - "${STAGED_FILES[@]}" << 'PYEOF'
import sys, json

files = []
for path in sys.argv[1:]:
    if not path:
        continue
    try:
        with open(path, 'r', encoding='utf-8', errors='replace') as f:
            content = f.read()
        files.append({"filePath": path, "content": content})
    except:
        pass

print(json.dumps({
    "command": "analyze",
    "payload": {
        "files": files,
        "aiProviderConfig": {"provider": "none"}
    }
}))
PYEOF
)
    
    # Run engine
    RESPONSE=$(echo "$PAYLOAD" | timeout 30 "$SECBIN" --mode pipe --format json 2>/dev/null) || true
    
    if [[ -z "$RESPONSE" ]]; then
        log_error "No response from engine"
        exit 0
    fi
    
    # Parse findings
    RESULT=$(python3 - "$RESPONSE" << 'PYEOF'
import sys, json

response = json.loads(sys.argv[1])
if response.get("status") != "success":
    print("ERROR:" + response.get("payload", {}).get("errorMessage", "unknown"))
    sys.exit(0)

findings = response.get("payload", {}).get("findings", [])
blocking = [f for f in findings if f.get("severity", "").lower() in ("critical", "high")]

print(json.dumps({
    "total": len(findings),
    "blocking": len(blocking),
    "findings": findings,
    "blocking_findings": blocking
}))
PYEOF
)
    
    if [[ "$RESULT" == ERROR:* ]]; then
        log_error "Engine error: ${RESULT#ERROR:}"
        exit 0
    fi
    
    TOTAL=$(echo "$RESULT" | python3 -c "import sys,json; print(json.load(sys.stdin)['total'])")
    BLOCKING=$(echo "$RESULT" | python3 -c "import sys,json; print(json.load(sys.stdin)['blocking'])")
    
    log_info "Found: $TOTAL findings ($BLOCKING blocking)"
    
    if [[ "$BLOCKING" -eq 0 ]]; then
        log_success "Commit allowed"
        exit 0
    fi
    
    # Show findings
    echo "" >&2
    log_error "COMMIT BLOCKED - $BLOCKING security finding(s)" >&2
    echo "" >&2
    
    python3 - "$RESPONSE" << 'PYEOF'
import sys, json

response = json.loads(sys.argv[1])
findings = response.get("payload", {}).get("findings", [])
blocking = [f for f in findings if f.get("severity", "").lower() in ("critical", "high")]

for i, f in enumerate(blocking, 1):
    sev = f.get("severity", "?").upper()
    print(f"  [{i}] {sev}: {f.get('title', '?')}")
    print(f"      {f.get('filePath', '?')}:{f.get('lineNumber', '?')}")
    print(f"      {f.get('message', '')}")
    print()
PYEOF

    # Ask user for mode
    # Show options
    echo "" >&2
    echo -e "  ${GREEN}[O]${NC}  Open GUI (recommended)" >&2
    echo -e "  ${CYAN}[T]${NC}  Terminal mode" >&2
    echo -e "  ${YELLOW}[Q]${NC}  Quit" >&2
    echo "" >&2
    
    # Try to read from /dev/tty
    if [[ -e /dev/tty ]]; then
        echo -n "  Select [O/T/Q]: " >&2
        choice=$(head -1 < /dev/tty | tr -d '\n')
    else
        choice="T"
    fi
    echo "" >&2
    
    if [[ -z "$choice" ]]; then
        choice="T"
    fi
    
    case "${choice^^}" in
        O)
            DESKTOP=$(find_desktop_app)
            if [[ -z "$DESKTOP" ]]; then
                log_warn "Desktop app not found, using terminal mode"
                choice="T"
            else
                log_info "Launching desktop app..."
                
                # Write findings to temp file
                local tmpfile
                tmpfile=$(mktemp)
                echo "$RESULT" > "$tmpfile"
                
                # Create output file for decision
                local outfile
                outfile=$(mktemp)
                
                # Launch electron - it will write decision and close
                REPO_PATH=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
                "$DESKTOP/node_modules/.bin/electron" "$DESKTOP" --findings-file "$tmpfile" --output-file "$outfile" --repo-path "$REPO_PATH" 2>&1
                
                # Read decision from output file
                local decision_data=""
                if [[ -f "$outfile" ]]; then
                    decision_data=$(cat "$outfile")
                fi
                
                rm -f "$tmpfile"
                
                if [[ -z "$decision_data" ]]; then
                    log_error "No decision from desktop app"
                    rm -f "$outfile"
                    exit 1
                fi
                
                # Parse the new CommitDecision format
                local allowed_files blocked_files resolved_count skipped_count modified_files
                allowed_files=$(echo "$decision_data" | python3 -c "import sys,json; d=json.load(sys.stdin); print('\n'.join(d.get('allowed',[])))" 2>/dev/null || echo "")
                blocked_files=$(echo "$decision_data" | python3 -c "import sys,json; d=json.load(sys.stdin); print('\n'.join(d.get('blocked',[])))" 2>/dev/null || echo "")
                resolved_count=$(echo "$decision_data" | python3 -c "import sys,json; print(json.load(sys.stdin).get('resolved_count',0))" 2>/dev/null || echo "0")
                skipped_count=$(echo "$decision_data" | python3 -c "import sys,json; print(json.load(sys.stdin).get('skipped_count',0))" 2>/dev/null || echo "0")
                modified_files=$(echo "$decision_data" | python3 -c "import sys,json; d=json.load(sys.stdin); print('\n'.join(d.get('modified_files',[])))" 2>/dev/null || echo "")
                
                rm -f "$outfile"
                
                # Unstage all files first
                git reset HEAD -- . 2>/dev/null || true
                
                # Re-stage only allowed files
                if [[ -n "$allowed_files" ]]; then
                    while IFS= read -r f; do
                        if [[ -n "$f" ]]; then
                            git add "$f" 2>/dev/null || true
                        fi
                    done <<< "$allowed_files"
                fi
                
                # Check if there are any files staged
                local staged_count
                staged_count=$(git diff --cached --name-only --diff-filter=ACM | wc -l)
                
                if [[ "$staged_count" -eq 0 ]]; then
                    log_error "No files to commit - all were blocked"
                    echo "" >&2
                    echo -e "  ${RED}╔══════════════════════════════════════╗${NC}" >&2
                    echo -e "  ${RED}║  Commit aborted — no clean files     ║${NC}" >&2
                    echo -e "  ${RED}╚══════════════════════════════════════╝${NC}" >&2
                    exit 1
                fi
                
                # Print stats summary
                echo "" >&2
                echo -e "${BOLD}╔══════════════════════════════════════════════════════════════════╗${NC}" >&2
                echo -e "${BOLD}║           SecretLens Resolution Summary                       ║${NC}" >&2
                echo -e "${BOLD}╚══════════════════════════════════════════════════════════════════╝${NC}" >&2
                echo "" >&2
                echo -e "  ${GREEN}Secrets resolved:${NC}  ${resolved_count}" >&2
                echo -e "  ${YELLOW}Skipped:${NC}           ${skipped_count}" >&2
                if [[ -n "$modified_files" ]]; then
                    echo "" >&2
                    echo -e "  ${BLUE}Modified files (secrets replaced with AWS refs):${NC}" >&2
                    while IFS= read -r f; do
                        [[ -n "$f" ]] && echo -e "    ${GREEN}✓${NC} $f" >&2
                    done <<< "$modified_files"
                fi
                if [[ -n "$blocked_files" ]]; then
                    echo "" >&2
                    echo -e "  ${RED}Excluded from commit (unresolved):${NC}" >&2
                    while IFS= read -r f; do
                        [[ -n "$f" ]] && echo -e "    ${RED}✗${NC} $f" >&2
                    done <<< "$blocked_files"
                fi
                echo "" >&2
                echo -e "  Committing ${staged_count} file(s)..." >&2
                echo "" >&2
                
                log_success "SecretLens: commit proceeding with clean files"
                exit 0
            fi
            ;;
        Q)
            log_error "Commit cancelled"
            exit 1
            ;;
    esac
    
    # Terminal mode
    log_info "Terminal mode selected"
    echo "" >&2
    echo -e "  ${GREEN}[A]${NC}  Allow anyway (not recommended)" >&2
    echo -e "  ${YELLOW}[Q]${NC}  Quit" >&2
    echo "" >&2
    
    if [[ -e /dev/tty ]]; then
        echo -n "  Select [A/Q]: " >&2
        choice=$(head -1 < /dev/tty | tr -d '\n')
    else
        choice="q"
    fi
    echo "" >&2
    
    if [[ -z "$choice" ]]; then
        choice="q"
    fi
    
    if [[ "${choice^^}" == "A" ]]; then
        log_warn "Committing despite security findings"
        exit 0
    else
        log_error "Commit cancelled"
        exit 1
    fi
}

main "$@"
